msgid "Time series variable to be predicted. (needed)"
msgstr "Variabel seri waktu untuk diprediksi. (diperlukan)"

msgctxt "predictiveAnalytics|"
msgid "Time"
msgstr "Waktu"

msgctxt "predictiveAnalytics|"
msgid ""
"Time variable that each corresponds to the time stamp of each observation. "
"Can be in the following formats: ['YYYY-MM-DD', 'YYYY/MM/DD', 'YYYY-MM-DD HH:"
"MM:SS', 'YYYY/MM/DD HH:MM:SS'] (needed)"
msgstr ""
"Variabel waktu yang setiap sesuai dengan stempel waktu setiap observasu. "
"Dapat berupa format berikut: ['YYYY-MM-DD', 'YYYY/MM/DD', 'YYYY-MM-DD "
"HH:MM:SS', 'YYYY/MM/DD HH:MM:SS'] (diperlukan)"

msgctxt "predictiveAnalytics|"
msgid "Covariates"
msgstr "Kovariat"

msgctxt "predictiveAnalytics|"
msgid "Covariates to be used in the prediction model. (optional)"
msgstr "Kovariat untuk digunakan di model prediksi. (opsional)"

